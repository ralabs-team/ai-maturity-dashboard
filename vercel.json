{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet, noimageindex"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/workspaces/:workspaceId/surveys/:surveyId",
      "destination": "/api/survey-definition?workspaceId=:workspaceId&surveyId=:surveyId"
    },
    {
      "source": "/api/survey-links/:linkId",
      "destination": "/api/survey-link?linkId=:linkId"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
